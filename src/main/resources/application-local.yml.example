# =============================================
# 本地开发配置文件模板
# 使用方法：复制此文件为 application-local.yml 并填入真实值
# cp application-local.yml.example application-local.yml
#
# ⚠️ application-local.yml 已在 .gitignore 中，不会被提交到 Git
# =============================================

# Spring AI 配置（阿里云 DashScope / 通义千问）
spring:
  ai:
    dashscope:
      api-key: your-dashscope-api-key-here
      model: qwen3-max
      result-format: message
      temperature: 0.7
      embedding:
        model: text-embedding-v2

  # 数据库配置（MySQL）
  datasource:
    url: jdbc:mysql://localhost:3306/tmp?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
    username: your-db-username
    password: your-db-password
    driver-class-name: com.mysql.cj.jdbc.Driver

# 搜索 API 配置
search-api:
  api-key: your-search-api-key-here
